# Secrets: configure these in Railway > Service > Variables. Never commit values.
PRIVATE_KEY=
WALLET_ADDRESS=
OPENAI_API_KEY=
CMC_PRO_API_KEY=

# OpenAI decision model. Change this in Railway without modifying code.
# Recommended default for this bot: gpt-5.6-terra
OPENAI_MODEL=gpt-5.6-terra

# Hyperliquid environment. Safe default is testnet.
# Set TESTNET=false only when the configured wallet/account is intended for mainnet trading.
TESTNET=true

# In Railway, reference the PostgreSQL service variable, for example:
# DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL=

# Persistent worker configuration.
BOT_INTERVAL_SECONDS=600
BOT_RUN_IMMEDIATELY=true
BOT_LOCK_ID=7260315

# PostgreSQL initialization retry configuration.
DB_INIT_ATTEMPTS=30
DB_INIT_RETRY_SECONDS=2
