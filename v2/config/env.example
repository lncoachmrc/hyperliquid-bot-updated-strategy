# Required: dedicated V2 PostgreSQL and public wallet address. No private key.
V2_DATABASE_URL=postgresql://user:password@host:5432/v2
V2_WALLET_ADDRESS=0x0000000000000000000000000000000000000000
V2_SYMBOLS=BTC,ETH,SOL

# Hard safety invariants.
V2_SHADOW_ONLY=true
V2_LIVE_TRADING_ENABLED=false

# Runtime cadence.
V2_FEATURE_INTERVAL_SECONDS=15
V2_POSITION_REVIEW_SECONDS=60
V2_ENTRY_REVIEW_SECONDS=300
V2_ENTRY_DECISION_COOLDOWN_SECONDS=60
V2_DEFAULT_STOP_PCT=0.60
V2_ROUND_TRIP_COST_BPS=10
V2_MAX_RISK_FRACTION=0.005
V2_MAX_EFFECTIVE_EXPOSURE=0.50
V2_QUANT_MINIMUM_SAMPLES=50

# Bidirectional failed-breakout reversal shadow engine.
V2_FAILED_BREAKOUT_ENABLED=true
V2_FAILED_BREAKOUT_SCAN_SECONDS=15
V2_FAILED_BREAKOUT_REPLAY_ENABLED=true
V2_FAILED_BREAKOUT_RISK_FRACTION=0.0015
V2_FAILED_BREAKOUT_MAX_EFFECTIVE_EXPOSURE=0.20

# Models are configurable and benchmarked; keys are optional because a deterministic shadow fallback exists.
V2_PRIMARY_PROVIDER=openai
V2_PRIMARY_MODEL=gpt-5
OPENAI_API_KEY=
V2_CHALLENGER_PROVIDER=anthropic
V2_CHALLENGER_MODEL=
ANTHROPIC_API_KEY=
V2_OBSERVER_PROVIDER=deepseek
V2_OBSERVER_MODEL=
DEEPSEEK_API_KEY=

# Daily Supervisor. It can only create a draft PR changing experimental_policy.json.
V2_SUPERVISOR_PROVIDER=openai
V2_SUPERVISOR_MODEL=gpt-5
V2_SUPERVISOR_TOKEN=replace-with-a-long-random-token
V2_GITHUB_TOKEN=
V2_GITHUB_REPOSITORY=lncoachmrc/hyperliquid-bot-updated-strategy
V2_GITHUB_BASE_BRANCH=main
